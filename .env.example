# Admin panel password (see /admin)
ADMIN_PASSWORD=SomenAdmin@2026

# GitHub Contents API — used by the admin panel to publish content edits as commits.
# Leave blank to instead enter these once in the admin panel's GitHub Connection
# settings (stored in the browser's localStorage).
GITHUB_TOKEN=
GITHUB_OWNER=
GITHUB_REPO=

# Gmail SMTP — contact forms (Hire Me + Contact pages), sent via /api/contact
# GMAIL_USER: the Gmail address used to send (e.g. your-name@gmail.com)
# GMAIL_APP_PASSWORD: a Gmail App Password (requires 2-Step Verification), not your normal password
# CONTACT_RECIPIENT: optional — inbox to deliver to; defaults to GMAIL_USER if unset
GMAIL_USER=
GMAIL_APP_PASSWORD=
CONTACT_RECIPIENT=

# Groq — powers the admin panel's Article Generator (free key at console.groq.com)
GROQ_API_KEY=

# Pexels — powers inline blog images (free key at pexels.com/api)
PEXELS_API_KEY=
